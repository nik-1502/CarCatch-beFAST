{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CarCatch: Start local server",
      "type": "process",
      "command": "python",
      "args": [
        "-u",
        "-m",
        "http.server",
        "8000",
        "--bind",
        "127.0.0.1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "carcatch-preview",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Serving HTTP on",
          "endsPattern": "^Serving HTTP on"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
